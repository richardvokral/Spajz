# Spajz environment variables
# Copy to `.env.local` and fill in. Every var here is OPTIONAL for local dev.

# --- Rohlik ---
# You sign in to Rohlik via OAuth (no password is ever sent to Spajz). The
# resulting token is stored in an encrypted HTTP-only cookie. Set this secret
# (32+ random chars) in production to key that encryption; a dev fallback is
# used if it's blank. Generate: openssl rand -base64 32
ROHLIK_TOKEN_SECRET=

# Rohlik OAuth registers only loopback redirect URIs. Default is
# http://localhost:8765/callback. If Rohlik rejects it, try an alternative such
# as http://127.0.0.1:8765/callback (the dashboard error will say if it does).
ROHLIK_OAUTH_REDIRECT=

# --- Database (Neon Postgres) ---
# Scaffold only. The MVP pantry lives in browser localStorage and does NOT
# touch the database. Needed for `npm run db:migrate` and Phase 2.
DATABASE_URL=

# --- Logto auth (optional) ---
# If ALL five are set, the /dashboard route requires sign-in.
# Leave them blank to run the app without login (dev bypass).
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3000
# Random string, at least 32 chars. Generate: openssl rand -base64 32
LOGTO_COOKIE_SECRET=
