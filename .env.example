# Spajz environment variables
# Copy to `.env.local` and fill in. Every var here is OPTIONAL for local dev.

# --- Rohlik ---
# NONE. Rohlik credentials are entered in the UI on every run and are never
# stored (not here, not in the database, not in the browser).

# --- Database (Neon Postgres) ---
# Scaffold only. The MVP pantry lives in browser localStorage and does NOT
# touch the database. Needed for `npm run db:migrate` and Phase 2.
DATABASE_URL=

# --- Logto auth (optional) ---
# If ALL five are set, the /dashboard route requires sign-in.
# Leave them blank to run the app without login (dev bypass).
LOGTO_ENDPOINT=
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_BASE_URL=http://localhost:3000
# Random string, at least 32 chars. Generate: openssl rand -base64 32
LOGTO_COOKIE_SECRET=
